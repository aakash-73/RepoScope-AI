# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster_id>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=reposcope_ai

# ─── Ollama (self-hosted LLM) ─────────────────────────────────────────────────
# Make sure Ollama is running: ollama serve
# Pull the model first:        ollama pull qwen2.5-coder:7b-instruct
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_ANALYSIS_MODEL=qwen2.5-coder:7b-instruct
OLLAMA_CHAT_MODEL=qwen2.5-coder:7b-instruct

# ─── GitHub (optional but recommended) ────────────────────────────────────────
# Without this: 60 API requests/hr  |  With this: 5000 requests/hr
GITHUB_TOKEN=your_github_token_here

# ─── CORS ─────────────────────────────────────────────────────────────────────
# For Local Dev  : ["http://localhost:5173", "http://localhost:3000"]
# For Production : ["http://your-server-ip", "https://your-domain.com"]
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]