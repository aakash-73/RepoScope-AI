# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=reposcope_ai

# ─── Ollama (self-hosted LLM) ─────────────────────────────────────────────────
# Make sure Ollama is running: ollama serve
# Pull the model first:        ollama pull qwen2.5-coder:7b-instruct
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_ANALYSIS_MODEL=qwen2.5-coder:7b-instruct
OLLAMA_CHAT_MODEL=qwen2.5-coder:7b-instruct

# ─── GitHub (optional but recommended) ────────────────────────────────────────
# Without this: 60 API requests/hr  |  With this: 5000 requests/hr
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─── Groq (no longer used — safe to delete these lines) ───────────────────────
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GROQ_REPO_ANALYSIS_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GROQ_REPO_CHAT_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx